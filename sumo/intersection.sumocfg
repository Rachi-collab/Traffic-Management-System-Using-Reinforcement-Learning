<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file value="intersection.net.xml"/>
        <route-files value="intersection.rou.xml"/>
    </input>

    <!-- ADD BELOW -->
    <time>
        <step-length value="0.5"/>
    </time>

    <processing>
        <collision.action value="warn"/>
        <ignore-route-errors value="true"/>
    </processing>
</configuration>